# Acelera Studio — variáveis do front-end (copie para .env)
#
# Supabase Auth (login dos colaboradores). Se ficar em branco, o login roda em
# MODO DEMO (qualquer usuário não-vazio entra) — útil pra ver a UI.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend FastAPI do gerador (geração de vídeo). Em produção, aponte para a API.
VITE_API_TARGET=http://127.0.0.1:8080
